{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist/server",
    "rootDir": "./src/backend",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/backend/*"]
    }
  },
  "include": ["src/backend/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/**/*.tsx", "src/services/**/*"]
}
