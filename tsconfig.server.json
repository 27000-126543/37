{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist/server",
    "rootDir": "./src/api",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/api/*"]
    }
  },
  "include": ["src/api/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/**/*.tsx", "src/**/*.ts"]
}
